@model FlightClientApp.Models.Flight

@{
    ViewData["Title"] = "Flight Details";
}

<h1>Flight Details</h1>

<table class="table">
    <tr>
        <th>Flight Number</th>
        <td>@Model.FlightNumber</td>
    </tr>
    <tr>
        <th>Departure DateTime</th>
        <td>@Model.DepartureDateTime.ToString("yyyy-MM-dd HH:mm")</td>
    </tr>
    <tr>
        <th>Departure Airport City</th>
        <td>@Model.DepartureAirportCity</td>
    </tr>
    <tr>
        <th>Arrival Airport City</th>
        <td>@Model.ArrivalAirportCity</td>
    </tr>
    <tr>
        <th>Duration (Minutes)</th>
        <td>@Model.DurationMinutes</td>
    </tr>
</table>

<div class="mt-3 mb-3">
    <a class="btn btn-primary me-2" asp-action="Update" asp-route-flightNumber="@Model.FlightNumber">Update</a>

    <form asp-action="Delete" asp-route-flightNumber="@Model.FlightNumber" method="post" style="display: inline;">
        <button type="submit" class="btn btn-danger">Delete</button>
    </form>
</div>

<a class="btn btn-secondary" asp-action="Index">Back to Search</a>

